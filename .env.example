# ──────────────────────────────────────────────────────────────
# Futurix Jarvis — Environment Configuration Template
# Copy this file to .env and customize the values.
# ──────────────────────────────────────────────────────────────

# ── Ollama LLM Settings ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# Tool execution mode: AUTO (probe model support), NATIVE (force native function calling), REACT (force text-based ReAct loop)
TOOL_EXECUTION_MODE=AUTO

# ── Available Models (comma-separated) ───────────────────────
OLLAMA_AVAILABLE_MODELS=llama3,qwen2,deepseek-coder-v2

# ── Voice Settings ───────────────────────────────────────────
WAKE_WORD=hey jarvis
VOICE_RATE=175
VOICE_VOLUME=0.9
VOICE_ID=

# ── Database ─────────────────────────────────────────────────
DB_PATH=data/jarvis.db

# ── RAG Knowledge Base ───────────────────────────────────────
KNOWLEDGE_DIR=knowledge_base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
VECTOR_DB_PATH=data/chroma_db
EMBEDDINGS_MODEL=nomic-embed-text

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── MCP Settings ─────────────────────────────────────────────
MCP_ENABLED=false
MCP_SERVERS_CONFIG=config/mcp_servers.json

# ── Safety ───────────────────────────────────────────────────
REQUIRE_CONFIRMATION_FOR_DELETE=true
REQUIRE_CONFIRMATION_FOR_SHUTDOWN=true
REQUIRE_CONFIRMATION_FOR_COMMANDS=true
